<?xml version="1.0" encoding="UTF-8"?>
<schemalist>
  <schema id="org.gnome.shell.extensions.minimized-windows-buttons" path="/org/gnome/shell/extensions/minimized-windows-buttons/">

    <key name="show-in-overview" type="b">
      <default>false</default>
    </key>

    <key name="per-workspace-buttons" type="b">
      <default>false</default>
    </key>

    <key name="position-on-screen" type="s">
      <default>'bottom'</default>
    </key>

    <key name="cover-behaviour" type="s">
      <default>'front'</default>
    </key>

    <key name="autohide-container-size" type="i">
      <default>3</default>
      <range min="0" max="50"/>
    </key>

    <key name="margin-vertical" type="i">
      <default>3</default>
      <range min="0" max="100"/>
      <summary>Button container: vertical margin</summary>
      <description>Vertical spacing, margin top for position top/margin bottom for position bottom</description>
    </key>

    <key name="margin-horizontal" type="i">
      <default>3</default>
      <range min="0" max="100"/>
      <summary>Button container: horizontal margin</summary>
      <description>Horizontal spacing</description>
    </key>

    <key name="margin-buttons" type="i">
      <default>1</default>
      <range min="0" max="20"/>
      <summary>button margins</summary>
      <description>space between buttons</description>
    </key>

    <key name="button-height" type="i">
      <default>36</default>
      <range min="5" max="100"/>
      <summary>button height</summary>
    </key>

    <key name="button-width" type="i">
      <default>150</default>
      <range min="20" max="500"/>
      <summary>button width</summary>
    </key>

    <key name="icon-height" type="i">
      <default>20</default>
      <range min="5" max="100"/>
      <summary>icon height</summary>
    </key>

    <key name="line-height" type="i">
      <default>16</default>
      <range min="5" max="100"/>
      <summary>text height</summary>
    </key>

    <key name="bg-color-r" type="i">
      <default>60</default>
      <range min="0" max="255"/>
      <summary>background color: r</summary>
    </key>

    <key name="bg-color-g" type="i">
      <default>60</default>
      <range min="0" max="255"/>
      <summary>background color: g</summary>
    </key>
    
    <key name="bg-color-b" type="i">
      <default>60</default>
      <range min="0" max="255"/>
      <summary>background color: b</summary>
    </key>

    <key name="bg-color-a" type="d">
      <default>1.0</default>
      <range min="0" max="1"/>
      <summary>background color: a</summary>
    </key>

    <key name="text-color-r" type="i">
      <default>250</default>
      <range min="0" max="255"/>
      <summary>background color: r</summary>
    </key>

    <key name="text-color-g" type="i">
      <default>250</default>
      <range min="0" max="255"/>
      <summary>background color: g</summary>
    </key>
    
    <key name="text-color-b" type="i">
      <default>250</default>
      <range min="0" max="255"/>
      <summary>background color: b</summary>
    </key>

    <key name="text-color-a" type="d">
      <default>1.0</default>
      <range min="0" max="1"/>
      <summary>background color: a</summary>
    </key>

    <key name="border-color-r" type="i">
      <default>250</default>
      <range min="0" max="255"/>
      <summary>background color: r</summary>
    </key>

    <key name="border-color-g" type="i">
      <default>250</default>
      <range min="0" max="255"/>
      <summary>background color: g</summary>
    </key>
    
    <key name="border-color-b" type="i">
      <default>250</default>
      <range min="0" max="255"/>
      <summary>background color: b</summary>
    </key>

    <key name="border-color-a" type="d">
      <default>0.0</default>
      <range min="0" max="1"/>
      <summary>background color: a</summary>
    </key>

    <key name="border-radius" type="i">
      <default>15</default>
      <range min="0" max="50"/>
      <summary>border radius</summary>
    </key>

    <key name="font-weight" type="i">
      <default>400</default>
      <range min="0" max="900"/>
      <summary>font weight</summary>
    </key>

    <key name="leave-space-margin" type="i">
      <default>3</default>
      <range min="0" max="50"/>
      <summary>font weight</summary>
    </key>

  </schema>
</schemalist>